# Admin dashboard environment configuration (PRD §8.6).
# Never expose secrets to client bundles. Vercel preview deployments must
# use staging values only (PRD §8.7).

# Deployment metadata (set by Vercel automatically; included for clarity)
# VERCEL_ENV=preview
# VERCEL_REGION=iad1

# Admin BFF -> Admin API base URL. Leave empty to use the in-memory mock store
# bundled with this app for the Phase 0 prototype.
ADMIN_API_BASE_URL=

# Session signing secret. Required in production. Use a cryptographically random
# 32+ byte value. The Phase 0 prototype uses an unsigned cookie; replace with
# verified OIDC tokens for production.
ADMIN_SESSION_SECRET=

# OIDC / SSO settings (production). Example fields; pick provider per PRD §11.1.
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=

# Audit log sink (production). Either a logging endpoint or DB credentials.
# AUDIT_LOG_ENDPOINT=
# AUDIT_LOG_API_KEY=

# Error reporting
# SENTRY_DSN=

# Feature flags
ADMIN_FEATURE_APPEALS=false
ADMIN_FEATURE_BULK_ACTIONS=false
