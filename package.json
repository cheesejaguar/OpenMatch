{
  "name": "openmatch",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source iOS dating app with an auditable matching algorithm and no paid dating advantage.",
  "license": "Apache-2.0",
  "workspaces": [
    "matching",
    "backend",
    "admin"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "license-inventory": "node scripts/license-inventory.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  }
}
