{
  "name": "@openmatch/backend",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset --force",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src test prisma"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.5.0",
    "@fastify/swagger": "^8.14.0",
    "@neondatabase/serverless": "^0.9.4",
    "@openmatch/matching": "*",
    "@prisma/adapter-neon": "^5.15.0",
    "@prisma/client": "^5.15.0",
    "@upstash/redis": "^1.31.0",
    "@vercel/blob": "^0.23.0",
    "@vercel/node": "^3.2.0",
    "ably": "^2.3.0",
    "fastify": "^4.26.0",
    "nodemailer": "^6.9.13",
    "pino-pretty": "^11.0.0",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^6.4.14",
    "@types/ws": "^8.5.10",
    "prisma": "^5.15.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
