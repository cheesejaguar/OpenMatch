# OpenMatch backend — local development configuration.
# Copy this file to .env and adjust as needed.

# Server
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# Database (Postgres + PostGIS via docker-compose)
DATABASE_URL=postgresql://openmatch:openmatch@localhost:5432/openmatch?schema=public

# Redis (cache, rate limits)
REDIS_URL=redis://localhost:6379

# JWT (use a real long random string in production; this is dev-only)
JWT_SECRET=dev-only-secret-change-me-in-production-please-replace
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Email magic-link (MailHog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@openmatch.local
MAGIC_LINK_TTL_SECONDS=900

# Apple Sign-In
APPLE_TEAM_ID=
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# GCS for photos (leave empty to use local filesystem fallback)
GCS_BUCKET=
GCS_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# Frontend / CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:8081

# Dev login (creates a backdoor test login; never set in production)
ALLOW_DEV_LOGIN=true
