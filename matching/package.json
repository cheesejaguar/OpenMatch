{
  "name": "@openmatch/matching",
  "version": "1.0.0",
  "description": "Open-source, auditable matching algorithm for OpenMatch.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": "./algorithm_config.json"
  },
  "files": ["dist", "algorithm_config.json", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src test"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/seedrandom": "^3.0.8",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "seedrandom": "^3.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
