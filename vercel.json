{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build -w @openmatch/matching && npm exec --workspace=@openmatch/backend -- prisma generate && npm run build -w @openmatch/backend",
  "installCommand": "npm install --include=dev",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "{backend/dist/**,backend/node_modules/.prisma/**,backend/node_modules/@prisma/client/**,node_modules/.prisma/**,node_modules/@prisma/client/**}"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "regions": ["iad1"]
}
