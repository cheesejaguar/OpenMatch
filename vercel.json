{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run build -w @openmatch/matching && npm --workspace @openmatch/backend exec -- prisma generate && npm run build -w @openmatch/backend",
  "functions": {
    "backend/dist/api/index.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "node_modules/.prisma/client/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/backend/dist/api/index" }],
  "regions": ["iad1"]
}
